---
import { ShieldCheck, Stethoscope, HeartHandshake, BadgeCheck } from "lucide-react";

const features = [
  { icon: Stethoscope, title: "Expert Surgeons", desc: "Highly experienced orthopedic specialists." },
  { icon: ShieldCheck, title: "Cashless Insurance", desc: "Hassle-free cashless treatment facility." },
  { icon: HeartHandshake, title: "Complete Care Support", desc: "Dedicated care coordinators for every patient." },
  { icon: BadgeCheck, title: "Advanced Technology", desc: "Latest minimally invasive surgical techniques." },
];
---

<section class="relative overflow-hidden bg-white py-20 sm:py-24">
  <div class="pointer-events-none absolute -top-32 right-0 w-96 h-96 bg-brand-100/60 rounded-full blur-3xl animate-soft-float" />
  <div
    class="pointer-events-none absolute bottom-0 -left-24 w-72 h-72 bg-accent-100/50 rounded-full blur-3xl animate-soft-float"
    style="animation-delay: -6s"
  />

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14 sm:mb-16" data-reveal>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 text-brand-700 text-xs font-semibold px-3 py-1 mb-4">
        WHY OPERATIONCOST
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-900 tracking-tight">
        Care that earns your trust
      </h2>
      <p class="text-neutral-600 mt-4 max-w-xl mx-auto">
        Trusted by thousands of patients across India for transparent,
        expert-led orthopedic care.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
      {
        features.map(({ icon: Icon, title, desc }, index) => (
          <div
            class="group relative bg-white rounded-3xl p-8 border border-neutral-100 hover:border-brand-200 hover:-translate-y-1.5 shadow-sm hover:shadow-xl hover:shadow-brand-900/10 transition-all duration-300"
            data-reveal
            style={`transition-delay: ${index * 80}ms`}
          >
            <div class="absolute top-0 left-8 right-8 h-px bg-gradient-to-r from-transparent via-brand-300 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500" />
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-500 to-brand-600 text-white flex items-center justify-center mb-6 shadow-lg shadow-brand-600/20 group-hover:scale-110 group-hover:-rotate-3 transition-transform duration-300">
              <Icon size={26} />
            </div>
            <h3 class="text-lg sm:text-xl font-bold mb-2.5 text-neutral-900">{title}</h3>
            <p class="text-neutral-600 text-sm sm:text-base leading-relaxed">{desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
