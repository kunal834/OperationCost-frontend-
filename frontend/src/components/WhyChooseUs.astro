---
import { ShieldCheck, Stethoscope, HeartHandshake, BadgeCheck } from "lucide-react";

const features = [
  { icon: Stethoscope, title: "Expert Surgeons", desc: "Highly experienced orthopedic specialists." },
  { icon: ShieldCheck, title: "Cashless Insurance", desc: "Hassle-free cashless treatment facility." },
  { icon: HeartHandshake, title: "Complete Care Support", desc: "Dedicated care coordinators for every patient." },
  { icon: BadgeCheck, title: "Advanced Technology", desc: "Latest minimally invasive surgical techniques." },
];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="text-4xl font-bold">Why Choose OperationCost?</h2>
      <p class="text-gray-600 mt-4">Trusted by thousands of patients across India.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        features.map(({ icon: Icon, title, desc }) => (
          <div class="bg-blue-50 rounded-3xl p-8 text-center hover:shadow-xl transition">
            <div class="text-blue-600 flex justify-center mb-5">
              <Icon size={40} />
            </div>
            <h3 class="text-xl font-bold mb-3">{title}</h3>
            <p class="text-gray-600">{desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
