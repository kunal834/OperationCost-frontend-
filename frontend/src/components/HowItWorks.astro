---
import { CalendarCheck, Stethoscope, Activity, HeartHandshake } from "lucide-react";

const steps = [
  { icon: CalendarCheck, title: "Book Consultation", desc: "Schedule a free consultation with our care experts." },
  { icon: Stethoscope, title: "Meet Specialist", desc: "Consult with experienced orthopedic surgeons." },
  { icon: Activity, title: "Treatment & Surgery", desc: "Receive advanced treatment using modern techniques." },
  { icon: HeartHandshake, title: "Recovery Support", desc: "Get complete post-surgery care and recovery support." },
];
---

<section class="relative overflow-hidden bg-brand-50 py-20 sm:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-16 sm:mb-20" data-reveal>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-white text-brand-700 text-xs font-semibold px-3 py-1 mb-4 shadow-sm">
        YOUR JOURNEY
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-900 tracking-tight">
        How It Works
      </h2>
      <p class="text-neutral-600 mt-4 max-w-xl mx-auto">
        Your journey to better health in 4 simple steps.
      </p>
    </div>

    <div class="relative grid sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10">
      <div class="hidden lg:block absolute top-8 left-[12.5%] right-[12.5%] border-t-2 border-dashed border-brand-300/70" />

      {
        steps.map(({ icon: Icon, title, desc }, index) => (
          <div class="relative text-center" data-reveal style={`transition-delay: ${index * 100}ms`}>
            <div class="relative z-10 mx-auto mb-6 w-16 h-16 rounded-2xl bg-white shadow-lg shadow-brand-900/10 flex items-center justify-center">
              <Icon size={28} className="text-brand-600" />
              <span class="absolute -top-2.5 -right-2.5 w-7 h-7 rounded-full bg-accent-600 text-white text-xs font-bold flex items-center justify-center shadow-md">
                {index + 1}
              </span>
            </div>
            <div class="bg-white rounded-3xl p-6 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 h-full">
              <h3 class="text-lg font-bold mb-2 text-neutral-900">{title}</h3>
              <p class="text-neutral-600 text-sm leading-relaxed">{desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
