---
import { Star, Quote } from "lucide-react";

const testimonials = [
  {
    name: "Rahul Sharma",
    treatment: "Knee Replacement",
    review: "Excellent experience with OperationCost. The entire surgery journey was smooth and hassle-free.",
  },
  {
    name: "Priya Verma",
    treatment: "Hip Replacement",
    review: "Doctors and care coordinators were very supportive. Highly recommended.",
  },
  {
    name: "Amit Singh",
    treatment: "Spine Surgery",
    review: "Transparent pricing and excellent medical support throughout the treatment.",
  },
];

const initials = (name) =>
  name
    .split(" ")
    .map((part) => part[0])
    .join("")
    .slice(0, 2);
---

<section class="relative overflow-hidden bg-neutral-50 py-20 sm:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14 sm:mb-16" data-reveal>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-white text-brand-700 text-xs font-semibold px-3 py-1 mb-4 shadow-sm">
        PATIENT STORIES
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-900 tracking-tight">
        What Our Patients Say
      </h2>
      <p class="text-neutral-600 mt-4 max-w-xl mx-auto">
        Trusted by thousands of happy patients.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {
        testimonials.map((item, index) => (
          <div
            class="relative bg-white rounded-3xl p-8 border border-neutral-100 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300"
            data-reveal
            style={`transition-delay: ${index * 80}ms`}
          >
            <Quote
              size={40}
              className="text-brand-50 absolute top-6 right-6"
              fill="currentColor"
              strokeWidth={0}
            />
            <div class="relative flex gap-1 text-accent-500 mb-5">
              {Array.from({ length: 5 }).map(() => (
                <Star size={16} fill="currentColor" />
              ))}
            </div>
            <p class="relative text-neutral-600 leading-relaxed mb-8">"{item.review}"</p>
            <div class="flex items-center gap-3 pt-6 border-t border-neutral-100">
              <div class="w-11 h-11 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 text-white flex items-center justify-center font-bold text-sm shrink-0">
                {initials(item.name)}
              </div>
              <div>
                <h3 class="font-bold text-neutral-900 leading-tight">{item.name}</h3>
                <p class="text-brand-600 text-sm">{item.treatment}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
