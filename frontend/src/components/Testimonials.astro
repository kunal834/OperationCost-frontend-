---
import { Star } from "lucide-react";

const testimonials = [
  {
    name: "Rahul Sharma",
    treatment: "Knee Replacement",
    review: "Excellent experience with OperationCost. The entire surgery journey was smooth and hassle-free.",
  },
  {
    name: "Priya Verma",
    treatment: "Hip Replacement",
    review: "Doctors and care coordinators were very supportive. Highly recommended.",
  },
  {
    name: "Amit Singh",
    treatment: "Spine Surgery",
    review: "Transparent pricing and excellent medical support throughout the treatment.",
  },
];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-14" data-reveal>
      <h2 class="text-4xl font-bold text-neutral-900">What Our Patients Say</h2>
      <p class="text-neutral-600 mt-4">Trusted by thousands of happy patients.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        testimonials.map((item, index) => (
          <div
            class="bg-neutral-50 rounded-3xl p-8 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
            data-reveal
            style={`transition-delay: ${index * 80}ms`}
          >
            <div class="flex gap-1 text-accent-500 mb-4">
              {Array.from({ length: 5 }).map(() => (
                <Star size={20} fill="currentColor" />
              ))}
            </div>
            <p class="text-neutral-600 mb-6">"{item.review}"</p>
            <h3 class="font-bold text-xl text-neutral-900">{item.name}</h3>
            <p class="text-brand-600">{item.treatment}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
