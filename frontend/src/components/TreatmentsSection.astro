---
import TreatmentCard from "./TreatmentCard.astro";
import treatmentDetails from "../data/treatments/index.js";

// Homepage teaser grid — the full 13-treatment list lives on /treatments.
const treatments = Object.entries(treatmentDetails)
  .slice(0, 8)
  .map(([slug, t]) => ({ slug, title: t.title, image: t.image }));
---

<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold">Our Orthopedic Treatments</h2>
      <p class="text-gray-600 mt-4">Advanced orthopedic treatments with expert care.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        treatments.map((t) => (
          <TreatmentCard slug={t.slug} title={t.title} image={t.image} />
        ))
      }
    </div>

    <div class="text-center mt-12">
      <a
        href="/treatments"
        class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-xl font-semibold transition-colors"
      >
        View All Treatments
      </a>
    </div>
  </div>
</section>
