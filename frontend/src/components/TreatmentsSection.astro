---
import TreatmentCard from "./TreatmentCard.astro";
import treatmentDetails from "../data/treatments/index.js";

// Homepage teaser grid — the full 13-treatment list lives on /treatments.
const treatments = Object.entries(treatmentDetails)
  .slice(0, 8)
  .map(([slug, t]) => ({ slug, title: t.title, image: t.image }));
---

<section class="py-20 bg-neutral-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12" data-reveal>
      <h2 class="text-4xl font-bold text-neutral-900">Our Orthopedic Treatments</h2>
      <p class="text-neutral-600 mt-4">Advanced orthopedic treatments with expert care.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        treatments.map((t, index) => (
          <TreatmentCard slug={t.slug} title={t.title} image={t.image} index={index} />
        ))
      }
    </div>

    <div class="text-center mt-12" data-reveal>
      <a
        href="/treatments"
        class="inline-block bg-brand-600 hover:bg-brand-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-brand-600/20 text-white px-8 py-4 rounded-xl font-semibold transition-all duration-200"
      >
        View All Treatments
      </a>
    </div>
  </div>
</section>
