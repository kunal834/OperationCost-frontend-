---
import { Image } from "astro:assets";
import {
  ShieldCheck,
  Calendar,
  Play,
  Users,
  ShieldPlus,
  HeartHandshake,
  Trophy,
  PhoneCall,
} from "lucide-react";
import heroImage from "../assets/hero/image.png";

const features = [
  { icon: Users, title: "Expert Surgeons", subtitle: "Highly Experienced" },
  { icon: ShieldPlus, title: "Advanced Care", subtitle: "Latest Technology" },
  {
    icon: HeartHandshake,
    title: "Complete Support",
    subtitle: "Every Step of the Way",
  },
];

const stats = [
  { icon: Users, value: "10,000+", label: "Happy Patients" },
  { icon: Trophy, value: "500+", label: "Successful Surgeries" },
  { icon: ShieldCheck, value: "50+", label: "Expert Doctors" },
  { icon: PhoneCall, value: "24/7", label: "Patient Support" },
];
---

<section class="relative overflow-hidden">
  <Image
    src={heroImage}
    alt="Orthopedic doctor consulting a patient"
    width={1264}
    height={842}
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-brand-950/90 via-brand-900/75 to-brand-900/45" />

  <div class="pointer-events-none absolute -top-24 -right-24 w-96 h-96 bg-brand-200/20 rounded-full blur-3xl animate-soft-float" />
  <div
    class="pointer-events-none absolute bottom-0 -left-24 w-72 h-72 bg-accent-300/10 rounded-full blur-3xl animate-soft-float"
    style="animation-delay: -4s"
  />

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-16 sm:py-24 lg:py-32">
    <div class="max-w-2xl" data-reveal>
      <span class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white px-4 py-2 rounded-full text-xs sm:text-sm font-semibold">
        <ShieldCheck size={16} /> Trusted Orthopedic Care
      </span>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mt-5 sm:mt-6 leading-[1.05] tracking-tight">
        <span class="text-white">Better Movement.</span>
        <br />
        <span class="text-brand-300">Better Life.</span>
      </h1>

      <p class="text-neutral-200 text-base sm:text-lg mt-5 sm:mt-6 max-w-md">
        Advanced orthopedic treatments with expert surgeons, modern
        technology & compassionate care.
      </p>

      <div class="grid grid-cols-3 gap-2 sm:gap-3 mt-6 sm:mt-8">
        {
          features.map(({ icon: Icon, title, subtitle }) => (
            <div class="bg-white/10 backdrop-blur-md rounded-2xl border border-white/20 p-3 sm:p-4 hover:-translate-y-1 hover:bg-white/15 transition-all duration-300">
              <span class="flex items-center justify-center w-9 h-9 rounded-xl bg-white/15 text-white mb-2">
                <Icon size={18} />
              </span>
              <p class="font-semibold text-white text-xs sm:text-sm leading-tight">{title}</p>
              <p class="text-neutral-300 text-[11px] sm:text-xs mt-0.5">{subtitle}</p>
            </div>
          ))
        }
      </div>

      <div class="flex flex-wrap gap-3 mt-6 sm:mt-8">
        <button
          data-open-popup
          class="cursor-pointer flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white px-6 py-3.5 rounded-xl font-semibold text-sm sm:text-base shadow-lg shadow-black/20 hover:-translate-y-0.5 transition-all duration-200"
        >
          <Calendar size={18} /> Book Free Consultation
        </button>
        <a
          href="/about"
          class="cursor-pointer flex items-center gap-2 border border-white/40 bg-white/10 backdrop-blur-sm text-white hover:bg-white/20 hover:-translate-y-0.5 px-6 py-3.5 rounded-xl font-semibold text-sm sm:text-base transition-all duration-200"
        >
          <Play size={16} /> How We Help
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6 mt-8 sm:mt-10 pt-6 border-t border-white/15">
        {
          stats.map(({ icon: Icon, value, label }) => (
            <div class="flex items-center gap-2.5">
              <span class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 backdrop-blur-sm text-white shrink-0">
                <Icon size={17} />
              </span>
              <div>
                <p class="font-bold text-white text-sm sm:text-base leading-tight">{value}</p>
                <p class="text-neutral-300 text-[11px] sm:text-xs">{label}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="hidden lg:flex absolute bottom-8 right-8 bg-brand-700/95 backdrop-blur-sm text-white p-5 rounded-2xl shadow-xl max-w-xs items-start gap-3">
    <span class="flex items-center justify-center w-10 h-10 rounded-full bg-white/15 shrink-0">
      <ShieldCheck size={20} />
    </span>
    <div>
      <p class="font-bold text-sm sm:text-base leading-tight">Safe. Trusted. Proven Care.</p>
      <p class="text-brand-100 text-xs sm:text-sm mt-1">
        Your health is our priority. We are with you, every step.
      </p>
    </div>
  </div>
</section>
