---
import { Image } from "astro:assets";

const { slug, title, image } = Astro.props;
---

<a
  href={`/treatments/${slug}`}
  class="bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition duration-300 hover:-translate-y-2 block"
>
  <div class="relative h-56 w-full bg-gray-100">
    <Image
      src={image}
      alt={title}
      loading="lazy"
      width={400}
      height={224}
      class="h-full w-full object-cover card-fade-in"
    />
  </div>
  <div class="p-6">
    <h3 class="text-xl font-bold">{title}</h3>
    <p class="text-blue-600 mt-3 font-semibold">Learn More →</p>
  </div>
</a>

<style>
  @keyframes card-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  .card-fade-in {
    animation: card-fade-in 0.4s ease-out;
  }
</style>
