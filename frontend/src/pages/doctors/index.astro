---
import Layout from "../../layouts/Layout.astro";
import DoctorSection from "../../components/DoctorSection.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { breadcrumbListSchema } from "../../lib/schema.js";

const seo = {
  title: "Our Doctors | Orthopedic Surgeons & Specialists | OperationCost",
  description:
    "Meet our board-certified orthopedic surgeons and specialists — knee, hip, spine, and sports injury experts ready to help you recover.",
  canonicalPath: "/doctors",
  jsonLd: breadcrumbListSchema(Astro.site, [
    { name: "Home", path: "/" },
    { name: "Doctors", path: "/doctors" },
  ]),
};
---

<Layout seo={seo}>
  <div class="relative overflow-hidden">
    <div class="pointer-events-none absolute -top-24 -right-20 w-96 h-96 bg-brand-100/50 rounded-full blur-3xl animate-soft-float" />
    <div
      class="pointer-events-none absolute top-20 -left-24 w-72 h-72 bg-accent-100/40 rounded-full blur-3xl animate-soft-float"
      style="animation-delay: -6s"
    />
    <div class="relative max-w-7xl mx-auto px-6 pt-20" data-reveal>
      <Breadcrumbs items={[{ name: "Home", path: "/" }, { name: "Doctors", path: "/doctors" }]} />
      <h1 class="text-5xl font-bold text-center mb-4 text-neutral-900">Our Expert Doctors</h1>
      <p class="text-center text-neutral-600 mb-10">
        Board-certified orthopedic specialists across joint replacement, spine,
        sports injury and trauma care.
      </p>
    </div>
  </div>
  <DoctorSection showViewAll={false} />
</Layout>
