---
import Layout from "../layouts/Layout.astro";

const seo = {
  title: "Page Not Found | OperationCost",
  description: "The page you're looking for doesn't exist or may have been moved.",
  canonicalPath: "/404",
  noindex: true,
};
---

<Layout seo={seo}>
  <div class="min-h-[70vh] flex items-center justify-center bg-brand-50 px-4">
    <div class="max-w-lg w-full text-center py-16" data-reveal>
      <p class="text-7xl md:text-8xl font-extrabold text-brand-600 mb-2 tracking-tight">404</p>
      <h1 class="text-2xl md:text-3xl font-semibold text-neutral-800 mb-3">Page Not Found</h1>
      <p class="text-neutral-500 mb-8">
        Sorry, the page you're looking for doesn't exist or may have been
        moved. Let's get you back to safe ground.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="flex items-center gap-2 px-6 py-3 bg-brand-600 text-white rounded-lg font-medium hover:bg-brand-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-brand-600/20 transition-all duration-200 w-full sm:w-auto justify-center"
        >
          Back to Home
        </a>
        <a
          href="/treatments"
          class="flex items-center gap-2 px-6 py-3 border border-neutral-300 bg-white text-neutral-700 rounded-lg font-medium hover:bg-neutral-50 hover:-translate-y-0.5 transition-all duration-200 w-full sm:w-auto justify-center"
        >
          Browse Treatments
        </a>
      </div>
      <button
        id="go-back"
        class="mt-6 flex items-center gap-1 text-sm text-neutral-500 hover:text-neutral-700 mx-auto"
      >
        ← Go back
      </button>
    </div>
  </div>
</Layout>

<script>
  document
    .getElementById("go-back")
    ?.addEventListener("click", () => window.history.back());
</script>
