---
import Layout from "../../layouts/Layout.astro";
import TreatmentCard from "../../components/TreatmentCard.astro";
import treatmentDetails from "../../data/treatments/index.js";
import { breadcrumbListSchema } from "../../lib/schema.js";

const treatments = Object.entries(treatmentDetails).map(([slug, t]) => ({
  slug,
  title: t.title,
  image: t.image,
}));

const seo = {
  title: "Orthopedic Treatments & Surgery Costs in India | OperationCost",
  description:
    "Explore knee, hip, shoulder, spine and sports injury treatments — compare costs, recovery timelines and connect with experienced orthopedic surgeons in India.",
  canonicalPath: "/treatments",
  jsonLd: breadcrumbListSchema(Astro.site, [
    { name: "Home", path: "/" },
    { name: "Treatments", path: "/treatments" },
  ]),
};
---

<Layout seo={seo}>
  <div class="relative overflow-hidden">
    <div class="pointer-events-none absolute -top-24 -right-20 w-96 h-96 bg-brand-100/50 rounded-full blur-3xl animate-soft-float" />
    <div
      class="pointer-events-none absolute top-40 -left-24 w-72 h-72 bg-accent-100/40 rounded-full blur-3xl animate-soft-float"
      style="animation-delay: -6s"
    />
  <div class="relative max-w-7xl mx-auto px-6 py-20">
    <div class="text-center mb-14" data-reveal>
      <span class="inline-block text-xs font-semibold tracking-wide text-brand-600 bg-brand-100 px-3 py-1 rounded-full mb-4">
        ALL TREATMENTS
      </span>
      <h1 class="text-4xl sm:text-5xl font-bold text-neutral-900">
        Orthopedic Treatments We Cover
      </h1>
      <p class="text-neutral-600 mt-4 max-w-2xl mx-auto">
        Compare costs, recovery timelines and treatment options across all our
        orthopedic and sports injury specialities — then book a free
        consultation with an experienced surgeon.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        treatments.map((t, index) => (
          <TreatmentCard slug={t.slug} title={t.title} image={t.image} index={index} />
        ))
      }
    </div>
  </div>
  </div>
</Layout>
